# Python-generated files
__pycache__/
*.py[oc]
build/
dist/
wheels/
*.egg-info

# Virtual environments
.venv

# Node
node_modules/
frontend/dist/
package-lock.json

# Playwright generated output
frontend/playwright-report/
frontend/test-results/
test-results/

# NAMD binary (download separately from UIUC)
NAMD_*/

# ── GROMACS simulation outputs ────────────────────────────────────────────────
# Trajectories and large binary outputs (not version-controlled)
*.xtc
*.trr
*.edr
*.tpr
*.cpt
*.gro
*.npz

# GROMACS scratch / auto-generated files
mdout.mdp
ions.mdp
ions.tpr
step*.pdb
\#*\#
.\#*

# Force field directories (installed system-wide, not project code)
*.ff/

# Run logs (stdout from bash run scripts — large, not useful in git)
run.log

# GROMACS per-phase logs (large, regenerable by re-running)
em.log
nvt.log
npt.log
prod.log

# Intermediate adapted PDB passed to pdb2gmx (input_nadoc.pdb is the canonical input)
input.pdb

# ── NAMD simulation outputs ──────────────────────────────────────────────────
# Trajectories and binary restart files (large, regenerable, not version-controlled)
*.dcd
*.dcd.BAK
*.restart.coor
*.restart.coor.old
*.restart.vel
*.restart.vel.old
*.restart.xsc.old
*.coor.BAK
*.vel.BAK
# NAMD per-run output directories (binary data)
experiments/*/results/*/output/
experiments/*/results/namd_run/
# Solvated run directories (large PSF/PDB/ITP outputs, never in git)
experiments/*/results/solvated/

# ── Bulk simulation run directories ──────────────────────────────────────────
bp_health_runs/
gromacs_run/
runs/
workspace/

# ── Literature and large binary assets ───────────────────────────────────────
Literature/
*.zip
*.tar.gz
*.tgz

# ── Claude Code memory (personal, machine-specific) ──────────────────────────
.claude/

# ── SSH keys (should never be committed) ─────────────────────────────────────
sshIDKEY
sshIDKEY.pub
id_rsa
id_rsa.pub
id_ed25519
id_ed25519.pub

# ── Misc logs ────────────────────────────────────────────────────────────────
monitor_v2.log

# ── Editor / tool local state (machine-specific, not user content) ───────────
.codex
.coverage
.vscode/
